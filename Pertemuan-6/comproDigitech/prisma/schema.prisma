generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Berita {
  id        Int      @id @default(autoincrement())
  judul     String
  slug      String   @unique
  isi       String   @db.Text
  gambar    String?
  createdAt DateTime @default(now())
}

model Layanan {
  id          Int      @id @default(autoincrement())
  nama        String
  deskripsi   String   @db.Text
  icon        String?
  createdAt   DateTime @default(now())
}

model Kontak {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String
  pesan     String   @db.Text
  createdAt DateTime @default(now())
}